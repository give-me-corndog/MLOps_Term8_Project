# =========================
# App
# =========================
APP_ENV=development
LOG_LEVEL=INFO
APP_BASE_URL=http://127.0.0.1:8000

# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
AUTHORIZED_TELEGRAM_CHAT_IDS=<your-telegram-chat-id-1>,<your-telegram-chat-id-2>
TELEGRAM_WEBHOOK_URL=<your-ngrok-url>/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=<your-webhook-secret>

# =========================
# Browser Use / LLM
# =========================
GOOGLE_API_KEY=<your-google-api-key>

# =========================
# eDimension Credentials
# Personal-use only
# =========================
EDIMENSION_USERNAME=<your-edimension-username>
EDIMENSION_PASSWORD=<your-edimension-password>

# =========================
# Local paths
# =========================
LOCAL_ARTIFACT_ROOT=./artifacts
DOWNLOADS_DIR=./artifacts/downloads
SCREENSHOTS_DIR=./artifacts/screenshots
VIDEOS_DIR=./artifacts/videos
TRACES_DIR=./artifacts/traces

# =========================
# Database
# =========================
SQLALCHEMY_DATABASE_URL=sqlite:///./app.db

# =========================
# DigitalOcean Spaces
# S3-compatible storage
# =========================
DO_SPACES_KEY=<your-digitalocean-spaces-key>
DO_SPACES_SECRET=<your-digitalocean-spaces-secret>
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=mlops-project
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# Optional: object URL base if you want to construct URLs yourself
DO_SPACES_PUBLIC_BASE_URL=<your-spaces-public-base-url>  # e.g., https://mlops-project.sgp1.digitaloceanspaces.com

# Prefix/folder inside the Space
DO_SPACES_PREFIX=edimension

# =========================
# Encryption / security
# =========================
APP_ENCRYPTION_KEY=<your-32-byte-base64-encoded-key>

# =========================
# Observability
# =========================
